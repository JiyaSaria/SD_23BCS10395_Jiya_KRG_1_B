        <mxCell id="fr-1" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="1. Search: Users must be able to search for events using filters – Event Title, City/Location, Date of Show." vertex="1">
