<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.3.0 Chrome/140.0.7339.249 Electron/38.7.2 Safari/537.36" version="29.3.0">
  <diagram name="Page-1" id="kafka_spark_nlp">
    <mxGraphModel dx="1789" dy="1344" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;strokeColor=none;fillColor=none;fontSize=14;fontStyle=1;" value="Aim: Real-Time Data Processing Pipeline using Apache Kafka, Spark Structured Streaming &amp;amp; Spark NLP" vertex="1">
          <mxGeometry height="30" width="1000" x="200" y="-40" as="geometry" />
        </mxCell>
        <mxCell id="fr-title" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=none;fillColor=none;fontStyle=1;fontSize=12;" value="A. Functional Requirements" vertex="1">
          <mxGeometry height="20" width="240" x="-100" y="-10" as="geometry" />
        </mxCell>
        <mxCell id="fr-body" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=none;fillColor=none;fontSize=11;" value="1. Real-time Data Ingestion: Consume streaming raw HTML data from Kafka topics in real time.&lt;br&gt;2. HTML Cleaning: Strip HTML tags and extract clean readable text from raw content.&lt;br&gt;3. Metadata Extraction: Parse and extract structured metadata – titles and paragraphs – from HTML.&lt;br&gt;4. Named Entity Recognition (NER): Detect and tag named entities (persons, organizations, locations) in text.&lt;br&gt;5. PII Redaction: Identify and redact sensitive Personally Identifiable Information from the processed data.&lt;br&gt;6. Batch Storage: Write cleaned and processed data to Parquet format for downstream analysis." vertex="1">
          <mxGeometry height="95" width="900" x="-100" y="12" as="geometry" />
        </mxCell>
        <mxCell id="nfr-title" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=none;fillColor=none;fontStyle=1;fontSize=12;" value="B. Non-Functional Requirements" vertex="1">
          <mxGeometry height="20" width="260" x="-100" y="115" as="geometry" />
        </mxCell>
        <mxCell id="nfr-body" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=none;fillColor=none;fontSize=11;" value="1. Scalability: Built on Apache Spark – horizontally scalable across a cluster for large-scale data volumes.&lt;br&gt;2. Low Latency: Stream processing must handle data with minimal lag; micro-batch checkpointing keeps state.&lt;br&gt;3. Fault Tolerance: Kafka consumer offsets and Spark checkpointing ensure at-least-once delivery and recovery.&lt;br&gt;4. Throughput: Must sustain high-throughput ingestion without backpressure accumulation.&lt;br&gt;5. Data Integrity: PII redaction must be complete before data lands in Parquet storage.&lt;br&gt;6. Extensibility: Pipeline must support adding new NLP models (sentiment analysis, classification) with minimal changes." vertex="1">
          <mxGeometry height="95" width="900" x="-100" y="137" as="geometry" />
        </mxCell>
        <mxCell id="cc-title" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=none;fillColor=none;fontStyle=1;fontSize=12;" value="C. Core Components (Project Modules)" vertex="1">
          <mxGeometry height="20" width="280" x="-100" y="240" as="geometry" />
        </mxCell>
        <mxCell id="cc-body" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=none;fillColor=none;fontSize=11;" value="1. app.py – Entry point: initialises Spark session, wires modules, starts the stream.&lt;br&gt;2. config.py – Central config: Kafka bootstrap servers, topic name, Spark master URL, Parquet storage path.&lt;br&gt;3. data_ingestion.py – Reads the Kafka stream; extracts URL and raw HTML content fields from each message.&lt;br&gt;4. data_processing.py – Spark NLP pipeline: cleans HTML → extracts metadata → runs NER → redacts PII.&lt;br&gt;5. pipeline.py – Orchestrates end-to-end flow: ties ingestion to processing, writes output to Parquet via foreachBatch." vertex="1">
          <mxGeometry height="85" width="900" x="-100" y="262" as="geometry" />
        </mxCell>
        <mxCell id="ts-title" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=none;fillColor=none;fontStyle=1;fontSize=12;" value="D. Technology Stack" vertex="1">
          <mxGeometry height="20" width="200" x="-100" y="355" as="geometry" />
        </mxCell>
        <mxCell id="ts-body" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=none;fillColor=none;fontSize=11;" value="Apache Kafka (Streaming Source)  |  Apache Spark Structured Streaming (Stream Engine)  |  Spark NLP (NER + PII Redaction)  |  PySpark (Language)  |  Parquet (Columnar Storage)" vertex="1">
          <mxGeometry height="20" width="1000" x="-100" y="377" as="geometry" />
        </mxCell>
        <mxCell id="cfg-title" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=none;fillColor=none;fontStyle=1;fontSize=12;" value="E. Key Configuration (config.py)" vertex="1">
          <mxGeometry height="20" width="260" x="-100" y="407" as="geometry" />
        </mxCell>
        <mxCell id="cfg-body" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=none;fillColor=none;fontSize=11;" value="KAFKA_BOOTSTRAP_SERVERS = &quot;kafka:9092&quot;  |  KAFKA_TOPIC = &quot;data-pipeline&quot;  |  SPARK_MASTER_URL = &quot;spark://spark-master:7077&quot;  |  STORAGE_PATH = &quot;./clean_data.parquet&quot;" vertex="1">
          <mxGeometry height="20" width="1000" x="-100" y="429" as="geometry" />
        </mxCell>
        <mxCell id="hld-title" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;strokeColor=none;fillColor=none;fontStyle=1;fontSize=13;" value="F. High-Level Design (HLD)" vertex="1">
          <mxGeometry height="22" width="280" x="-100" y="462" as="geometry" />
        </mxCell>
        <mxCell id="app-ann" parent="1" style="text;html=1;align=center;verticalAlign=top;resizable=0;strokeColor=none;fillColor=none;fontSize=10;fontStyle=2;" value="Initialises SparkSession → wires config.py → calls data_ingestion → data_processing → pipeline.py → starts stream" vertex="1">
