        <mxCell id="sOLaZpKRdjkeHPjkyI0H-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="ODD -&amp;gt; design hotstart like application&lt;br&gt;1.user service&lt;br&gt;2.movie search&lt;br&gt;&lt;br&gt;3. subsciption service&lt;br&gt;4.movie play&lt;br&gt;use cdc pipleine, hls dash, manifest file, proxy design pattern&amp;nbsp;" vertex="1">
